# React (CRA) environment variables must be prefixed with REACT_APP_
# Copy this file to .env.local (recommended) or .env

# Backend API base URL
REACT_APP_API_URL=http://localhost:5000/api

# Production Backend API URL
REACT_APP_PRODUCTION_API_URL=https://api.sarxlabs.online/api

# Stripe Publishable Key
REACT_APP_STRIPE_PUBLISHABLE_KEY=

# Environment
REACT_APP_ENVIRONMENT=development
